---
import { siteConfig } from '../data/config';
import { heroCode } from '../data/hero-code';
import Icon from './Icon.astro';

async function getGitHubStars(): Promise<number | null> {
  try {
    const response = await fetch('https://api.github.com/repos/LarsArtmann/go-error-family', {
      headers: {
        'Accept': 'application/vnd.github.v3+json',
      },
    });
    if (!response.ok) return null;
    const data = await response.json();
    return data.stargazers_count as number;
  } catch {
    return null;
  }
}

const stars = await getGitHubStars();
const starsText = stars !== null ? `${stars} Stars` : 'Star on GitHub';

const importPath = siteConfig.github.replace('https://github.com/', 'github.com/');

const highlightedCode = `<span class="text-text-muted">package</span> <span class="text-text-secondary">main</span>

<span class="text-text-muted">import</span> (
    <span class="text-text-muted">"errors"</span>
    <span class="text-text-muted">"os"</span>

    errorfamily <span class="text-accent-hover">"${importPath}"</span>
)

<span class="text-text-muted">func</span> <span class="text-accent">main</span>() {
    err := errors.<span class="text-accent">New</span>(<span class="text-amber">"connection refused"</span>)

    <span class="text-code-comment">// Classify any error into a behavioral family</span>
    family := errorfamily.<span class="text-accent">Classify</span>(err)
    <span class="text-code-comment">// &rarr; Transient (unknown errors are retryable)</span>

    <span class="text-text-muted">if</span> errorfamily.<span class="text-accent">IsRetryable</span>(err) {
        retry() <span class="text-code-comment">// backoff/jitter are yours</span>
    }

    os.<span class="text-accent">Exit</span>(errorfamily.<span class="text-accent">ExitCode</span>(err))
    <span class="text-code-comment">// &rarr; 75 (EX_TEMPFAIL)</span>
}`;

const metrics = [
  { value: '5', label: 'Families' },
  { value: '~9', label: 'ns Classify' },
  { value: '0', label: 'Allocs' },
  { value: 'MIT', label: 'License' },
];
---

<section class="relative flex items-center justify-center overflow-hidden pt-36 pb-20">
  <div class="absolute top-1/4 left-1/2 -translate-x-1/2 w-[900px] h-[500px] bg-accent/5 blur-[140px] rounded-full pointer-events-none"></div>
  <div class="relative max-w-3xl xl:max-w-7xl mx-auto px-6 text-center">
    <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-border bg-bg-card-solid text-xs font-mono text-text-secondary mb-8 backdrop-blur-sm">
      <span class="relative flex w-2 h-2">
        <span class="animate-pulse-dot absolute inline-flex w-full h-full rounded-full bg-accent"></span>
        <span class="relative inline-flex rounded-full w-2 h-2 bg-accent"></span>
      </span>
      Structured error protocol for Go
    </div>

    <h1 class="text-[clamp(2.75rem,8vw,4.5rem)] font-bold tracking-tighter leading-[1.05] mb-6 text-text-primary">
      Stop guessing what to <span class="text-accent">do</span> with errors.
    </h1>

    <p class="text-[clamp(1.0625rem,2.5vw,1.25rem)] text-text-secondary max-w-2xl mx-auto mb-10 leading-relaxed">
      Behavioral classification, exit codes, HTTP status mapping, and diagnostic rules. One concept &mdash; Family &mdash; answers retry, exit code, HTTP status, and tone.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-3 mb-12">
      <a href="/getting-started/installation/" data-astro-prefetch class="px-6 py-3 bg-accent text-bg-primary font-semibold rounded-lg text-sm hover:bg-accent-hover transition-all duration-200 inline-flex items-center gap-2 border-none cursor-pointer shadow-lg shadow-accent/20 hover:shadow-accent/30 hover:-translate-y-0.5">
        Get Started
        <Icon name="arrow-right" size={16} />
      </a>
      <a href={siteConfig.github} target="_blank" rel="noopener noreferrer" class="px-6 py-3 border border-border text-text-secondary font-medium rounded-lg text-sm hover:border-border-hover hover:text-text-primary transition-all duration-200 inline-flex items-center gap-2 no-underline hover:-translate-y-0.5">
        <Icon name="star" size={14} />
        {starsText}
      </a>
    </div>

    <div class="flex items-center justify-center gap-6 md:gap-10 mb-16 max-w-xl mx-auto">
      {metrics.map((metric, index) => (
        <>
          {index > 0 && <div class="w-px h-10 bg-border shrink-0"></div>}
          <div class="text-center">
            <div class="text-xl font-bold text-text-primary font-mono">{metric.value}</div>
            <div class="text-xs text-text-muted mt-0.5">{metric.label}</div>
          </div>
        </>
      ))}
    </div>

    <div class="relative max-w-xl mx-auto">
      <div class="absolute -inset-4 bg-gradient-to-r from-accent/8 via-transparent to-accent/8 rounded-2xl pointer-events-none"></div>
      <div class="relative rounded-xl border border-border bg-bg-code shadow-2xl overflow-hidden code-preview">
        <div class="flex items-center gap-1.5 px-4 py-3 border-b border-border bg-bg-card-solid/50">
          {Array(3).fill(null).map(() => (
            <span class="w-2.5 h-2.5 rounded-full bg-code-dot"></span>
          ))}
          <span class="ml-3 text-xs text-text-muted font-mono">main.go</span>
        </div>
        <pre class="p-5 text-left text-[0.8125rem] font-mono leading-[1.7] overflow-x-auto relative"><code id="hero-code" set:html={highlightedCode} /></pre>
        <button class="absolute top-2 right-2 bg-code-inline-bg/80 border border-border rounded-md text-text-muted px-2 py-1 cursor-pointer text-xs font-mono hover:text-text-primary hover:border-border-hover transition-all duration-150 opacity-0 [.code-preview:hover_&]:opacity-100" id="copy-btn" data-code={heroCode} aria-label="Copy code to clipboard">Copy</button>
      </div>
    </div>
  </div>
</section>

<script is:inline src="/js/copy-code.js"></script>
