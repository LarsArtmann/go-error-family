---
export interface Props {
  width?: number;
  height?: number;
  class?: string;
}

const { width = 28, height = 28, class: className } = Astro.props;
---

<svg class={className} width={width} height={height} viewBox="0 0 28 28" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="go-error-family logo">
  <rect width="28" height="28" rx="6" class="fill-[var(--color-accent)]" />
  <rect x="6" y="6.5" width="16" height="3" rx="1.5" class="fill-[var(--color-bg-primary)]" />
  <rect x="6" y="12.5" width="12" height="3" rx="1.5" class="fill-[var(--color-bg-primary)]" />
  <rect x="6" y="18.5" width="8" height="3" rx="1.5" class="fill-[var(--color-bg-primary)]" />
</svg>
