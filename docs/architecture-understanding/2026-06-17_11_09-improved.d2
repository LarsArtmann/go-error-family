direction: down

# ─── IDEAL ARCHITECTURE (v1.0 target) ───

core_mod: "Core Module (v1.0 STABLE)\ngithub.com/larsartmann/go-error-family\n— Family, Error, Interfaces\n— Classify, Registry, HandleError\n— Constructors\n— Zero external deps\n— ~1000 LOC" {
  style.fill: "#e8efe9"
  style.stroke: "#1a5c3a"
  style.stroke-width: 2
}

diagnose_mod: "Diagnose Module (v0.x EXPERIMENTAL)\ngithub.com/.../diagnose\n— DiagnosticRule, Runner\n— FilesystemRule, NetworkRule\n— CommandRunner, MockCommandRunner\n— Helpers (FamilyIs, ErrorContext)\n— Zero external deps" {
  style.fill: "#faf6e8"
  style.stroke: "#8a6d00"
}

agent_mod: "Agent Module (v0.x EXPERIMENTAL)\ngithub.com/.../agent\n— DebugAgent interface\n— deterministicAnalyze\n— FixStep suggestions\n— Zero external deps" {
  style.fill: "#faf6e8"
  style.stroke: "#8a6d00"
}

bridge_mod: "Bridge Module (v0.x EXPERIMENTAL)\ngithub.com/.../bridge\n— ClassifiedError\n— Wrap, AutoWrap, InferFamily" {
  style.fill: "#fbf0ee"
  style.stroke: "#c23a22"
}

git_mod: "Git Submodule (v0.x)\ngithub.com/.../diagnose/git\n— GitRule" {
  style.fill: "#fbf0ee"
  style.stroke: "#c23a22"
}

pg_mod: "Postgres Submodule (v0.x)\ngithub.com/.../diagnose/postgres\n— PostgresRule" {
  style.fill: "#fbf0ee"
  style.stroke: "#c23a22"
}

examples: "examples/cmd/ (stays in core repo)\n— cli, http, custom_rule\n— LEAF nodes, compiled in CI" {
  style.fill: "#f0f0ec"
  style.stroke: "#d4d4d0"
}

# ─── DEPENDENCY EDGES (clean DAG) ───
diagnose_mod -> core_mod: "errorfamily.Classify\nerrorfamily.Family\nerrorfamily.Contextual"
agent_mod -> diagnose_mod: "diagnose.DiagnosticResult\ndiagnose.StatusFailed"
agent_mod -> core_mod: "errorfamily.Classify"
bridge_mod -> core_mod: "errorfamily.Family\nerrorfamily.IsRetryable"
git_mod -> diagnose_mod: "diagnose.CommandRunner\ndiagnose.RuleSpec"
git_mod -> core_mod: "(via diagnose)"
pg_mod -> diagnose_mod: "diagnose.FamilyIs\ndiagnose.CommandRunner"
pg_mod -> core_mod: "errorfamily.Transient"
examples -> core_mod: "NewRejection, HandleError"

external_oops: "samber/oops" {
  style.fill: "#f0f0ec"
  style.stroke: "#d4d4d0"
}
bridge_mod -> external_oops: "oops.OopsError"

legend: |label
  GREEN = v1.0 stable — frozen API, semver guarantees
  YELLOW = v0.x experimental — separate module, independent versioning
  RED = integration submodules — opt-in, pinned to core
  GRAY = external dependency / examples

  KEY CHANGE: agent/ and diagnose/ extracted from root module.
  Root module shrinks to classification core only.
  Each module versions independently.
  No experimental code in the v1.0 stable module.
|
